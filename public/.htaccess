Options -MultiViews
RewriteEngine On
RewriteCond %{REQUEST_FILENAME} !-f
RewriteRule ^ index.html [QSA,L]

# Never cache index.html or service worker — always fetch fresh
<FilesMatch "^(index\.html|sw\.js|registerSW\.js|manifest\.webmanifest)$">
  Header set Cache-Control "no-cache, no-store, must-revalidate"
  Header set Pragma "no-cache"
  Header set Expires "0"
</FilesMatch>

# Cache hashed assets long-term (filenames change on each build)
<FilesMatch "\.(js|css|png|ico|woff2|svg)$">
  Header set Cache-Control "public, max-age=31536000, immutable"
</FilesMatch>
